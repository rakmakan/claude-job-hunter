{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job Hunter Spec",
  "description": "User profile and job search preferences generated by /job-brainstorm",
  "type": "object",
  "required": ["version", "created", "personal", "demographics", "targeting", "resume_context", "preferences"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "personal": {
      "type": "object",
      "required": ["name", "email", "phone", "address"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": {
          "type": "object",
          "required": ["city", "province", "country"],
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "province": { "type": "string" },
            "postal": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "linkedin": { "type": "string", "format": "uri" },
        "github": { "type": "string", "format": "uri" },
        "portfolio": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "demographics": {
      "type": "object",
      "required": ["work_authorization", "sponsorship_needed"],
      "properties": {
        "gender": { "type": "string" },
        "sexual_orientation": { "type": "string" },
        "race_ethnicity": { "type": "string" },
        "veteran": { "type": "boolean" },
        "disability": { "type": "string", "enum": ["yes", "no", "prefer_not_to_answer"] },
        "work_authorization": { "type": "string", "enum": ["citizen", "permanent_resident", "work_permit", "need_sponsorship"] },
        "sponsorship_needed": { "type": "boolean" }
      }
    },
    "targeting": {
      "type": "object",
      "required": ["roles", "locations", "work_mode"],
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "companies": { "type": "array", "items": { "type": "string" } },
        "discover_companies": { "type": "boolean" },
        "industries": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "work_mode": {
          "type": "array",
          "items": { "type": "string", "enum": ["remote", "hybrid", "onsite"] },
          "minItems": 1
        },
        "salary_range": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "currency": { "type": "string" }
          }
        },
        "availability": { "type": "string", "format": "date" }
      }
    },
    "resume_context": {
      "type": "object",
      "required": ["resume_path", "current_title", "years_experience"],
      "properties": {
        "resume_path": { "type": "string" },
        "current_title": { "type": "string" },
        "years_experience": { "type": "number" },
        "key_strengths": { "type": "array", "items": { "type": "string" } },
        "downplay": { "type": "array", "items": { "type": "string" } }
      }
    },
    "preferences": {
      "type": "object",
      "required": ["cover_letter_tone"],
      "properties": {
        "cover_letter_tone": { "type": "string", "enum": ["formal", "professional_conversational", "technical"] },
        "relocate": { "type": "boolean" },
        "company_size": {
          "type": "array",
          "items": { "type": "string", "enum": ["startup", "mid", "enterprise"] }
        },
        "deal_breakers": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
